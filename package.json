{
  "name": "gmail-search-tools",
  "version": "0.0.0.1",
  "description": "Alfred workflow for quick access to Gmail search",
  "config": {
    "workflow_source": "src",
    "dist_name": "gmail-search-tools",
    "workflow_file": "gmail-search-tools.alfredworkflow"
  },
  "scripts": {
    "test": "node scripts/run-python.js -m pytest tests/",
    "build": "gulp build",
    "dev": "gulp dev",
    "lint": "node scripts/run-python.js -m pylint src/script/*.py",
    "install-python-deps": "python3 -m venv .venv && .venv/bin/python3 -m pip install -r requirements.txt"
  },
  "devDependencies": {
    "del": "^6.1.1",
    "eslint": "^8.57.0",
    "gulp": "^4.0.2",
    "gulp-zip": "^5.1.0",
    "xml2js": "^0.6.2"
  }
}
